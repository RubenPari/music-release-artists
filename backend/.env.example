# Node
TZ=UTC
PORT=3333
HOST=127.0.0.1
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://127.0.0.1:5173

# Database
DB_CONNECTION=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_DATABASE=

# Session
SESSION_DRIVER=cookie

# CORS (comma-separated in production)
# CORS_ORIGINS=https://example.com

# Spotify — in Dashboard: Redirect URIs must match SPOTIFY_REDIRECT_URI exactly (scheme, host, port, path, no extra slash).
# Local default (backend PORT=3333): add this exact string in Spotify Developer → your app → Redirect URIs
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3333/api/v1/spotify/callback

# Mailtrap (for development)
MAILTRAP_API_KEY=
MAILTRAP_FROM_EMAIL=
MAILTRAP_FROM_NAME=