# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://localhost:5173

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3333/api/v1/spotify/callback

# Email (Mailtrap/SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Mailtrap API (Transactional Email)
MAILTRAP_API_KEY=
MAILTRAP_INBOX_ID=
MAILTRAP_SANDBOX=true

# Email Sender
EMAIL_FROM_EMAIL=noreply@example.com
EMAIL_FROM_NAME=Music Release Artists
